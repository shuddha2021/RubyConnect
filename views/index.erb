<!-- Hero -->
<section class="hero">
  <h1>User Management</h1>
  <p>Manage your team with ease. Search, create, edit, and remove users in one place.</p>
</section>

<!-- KPI Strip -->
<div class="kpi-strip">
  <div class="kpi"><span class="kpi-val"><%= @stats[:total] %></span><span class="kpi-label">Total Users</span></div>
  <div class="kpi"><span class="kpi-val"><%= @stats[:admins] %></span><span class="kpi-label">Admins</span></div>
  <div class="kpi"><span class="kpi-val"><%= @stats[:members] %></span><span class="kpi-label">Members</span></div>
  <div class="kpi"><span class="kpi-val"><%= @stats[:viewers] %></span><span class="kpi-label">Viewers</span></div>
</div>

<!-- Toolbar -->
<div class="toolbar">
  <form method="get" action="/" class="search-form">
    <input type="search" name="q" value="<%= h(@search) %>" placeholder="Search users..." class="search-input" aria-label="Search users">
    <button type="submit" class="btn btn-primary btn-sm">Search</button>
    <% unless @search.empty? %>
      <a href="/" class="btn btn-ghost btn-sm">Clear</a>
    <% end %>
  </form>
  <div class="toolbar-actions">
    <a href="/users/new" class="btn btn-primary">+ New User</a>
    <button class="btn btn-ghost" id="contactBtn">Contact</button>
  </div>
</div>

<!-- User Table -->
<div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @users.empty? %>
        <tr>
          <td colspan="6" class="empty-state">
            <% if @search.empty? %>
              No users yet. <a href="/users/new">Create one</a>.
            <% else %>
              No results for "<%= h(@search) %>". <a href="/">Clear search</a>.
            <% end %>
          </td>
        </tr>
      <% else %>
        <% @users.each do |user| %>
          <tr>
            <td class="mono"><%= user['id'] %></td>
            <td class="name-cell"><%= h(user['name']) %></td>
            <td class="mono"><%= h(user['email']) %></td>
            <td><span class="badge badge-<%= user['role'] %>"><%= user['role'] %></span></td>
            <td class="mono"><%= user['created_at'] %></td>
            <td class="text-right actions-cell">
              <a href="/users/<%= user['id'] %>/edit" class="btn btn-sm btn-ghost">Edit</a>
              <form method="post" action="/users/<%= user['id'] %>/delete" class="inline-form" onsubmit="return confirm('Delete <%= h(user['name']) %>?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<% if @total_pages > 1 %>
  <nav class="pagination" aria-label="Pages">
    <% if @page > 1 %>
      <a href="/?page=<%= @page - 1 %><%= @search.empty? ? '' : "&q=#{h(@search)}" %>" class="btn btn-sm btn-ghost">&larr; Prev</a>
    <% end %>
    <span class="page-info">Page <%= @page %> of <%= @total_pages %></span>
    <% if @page < @total_pages %>
      <a href="/?page=<%= @page + 1 %><%= @search.empty? ? '' : "&q=#{h(@search)}" %>" class="btn btn-sm btn-ghost">Next &rarr;</a>
    <% end %>
  </nav>
<% end %>
