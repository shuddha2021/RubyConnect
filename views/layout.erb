<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RubyConnect</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a class="nav-brand" href="/">💎 RubyConnect</a>
      <div class="nav-links">
        <a href="/" class="nav-link">Users</a>
        <a href="/users/new" class="nav-link">+ New</a>
        <button class="theme-btn" id="themeBtn" title="Toggle theme">🌓</button>
      </div>
    </div>
  </nav>

  <main class="main">
    <% if (f = consume_flash) %>
      <div class="alert alert-<%= f[:type] %>" role="alert">
        <%= f[:message] %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="footer">
    Built by <a href="https://github.com/shuddha2021" target="_blank" rel="noopener">Shuddha Chowdhury</a> &mdash;
    <a href="https://github.com/shuddha2021/RubyConnect" target="_blank" rel="noopener">Source</a>
  </footer>

  <!-- Contact Modal -->
  <div class="modal-backdrop" id="contactBackdrop"></div>
  <div class="modal" id="contactModal" role="dialog" aria-labelledby="contactTitle" aria-modal="true">
    <div class="modal-header">
      <h2 id="contactTitle">Contact Us</h2>
      <button class="modal-close" id="contactClose" aria-label="Close">&times;</button>
    </div>
    <form method="post" action="/contact">
      <div class="modal-body">
        <div class="field">
          <label for="contact_name">Name</label>
          <input type="text" id="contact_name" name="contact_name" required>
        </div>
        <div class="field">
          <label for="contact_email">Email</label>
          <input type="email" id="contact_email" name="contact_email" required>
        </div>
        <div class="field">
          <label for="contact_message">Message</label>
          <textarea id="contact_message" name="contact_message" rows="4" required></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" id="contactCancel">Cancel</button>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </div>
    </form>
  </div>

  <script src="/app.js"></script>
</body>
</html>
